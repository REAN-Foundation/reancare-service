<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{content.Header.MainTitle}} – Pamphlet (1 Page)</title>
  
  <!--
    PDF GENERATION SETTINGS:
    
    If using Puppeteer, add these options:
    {
      printBackground: true,
      preferCSSPageSize: true
    }
    
    If using wkhtmltopdf, add these flags:
    --print-media-type
    --enable-local-file-access
    --background
    
    If colors still don't show, check your backend PDF library configuration.
  -->
  
  <style>
    /* PRINT & PAGE SIZING */
    @page { size: A4; margin: 5mm; }

    :root{
      --primary: {{{styling.Primary}}} ;
      --secondary: {{{styling.Secondary}}} ;
      --accent: {{{styling.Accent}}} ;
      --light-bg: {{{styling.LightBg}}} ;
      --panel: {{{styling.Panel}}} ;
      --muted: {{{styling.Muted}}} ;
      --text: {{{styling.Text}}} ;
      --heading-font: {{{styling.HeadingFont}}} ;
      --body-font: {{{styling.BodyFont}}} ;
      --page-width: {{{styling.PageWidth}}} ;
      --page-height: {{{styling.PageHeight}}} ;
      --user-interface-width: {{{styling.UserInterfaceWidth}}} ;
      --user-interaction-width: {{{styling.UserInteractionWidth}}} ;
      --qr-size: {{{styling.QrSize}}} ;
    }

    * { box-sizing: border-box; }

    /* Force background colors and gradients in PDF */
    * {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      color-adjust: exact !important;
    }

    @media print {
      * {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        color-adjust: exact !important;
      }
      .page { margin:0; box-shadow:none; }
      .partner-logos img, .title-image, .user-interface-image img, .last-cta .cta-qr img { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
  </style>
</head>
<body style="margin: 0; padding: 0; background: #f5f5f5; font-family: {{{styling.BodyFont}}}, Arial, sans-serif; color: {{{styling.Text}}};">

  <!-- SINGLE PAGE - ALL CONTENT -->
  <div class="page" style="width: calc(210mm - 10mm); height: calc(297mm - 10mm); margin: 0 auto; background: #fff; display: flex; flex-direction: column; page-break-after: always; position: relative; overflow: hidden; padding-bottom: 25px; box-shadow: none;">

    <!-- Compact Hero Section with Gradient -->
    <div class="hero-section" style="width: 100%; min-height: 220px; position: relative; overflow: visible; margin: 0;">
      
      <!-- SVG Gradient Background (Primary to Secondary) -->
      <svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0;" preserveAspectRatio="none">
        <defs>
          <linearGradient id="heroBgGradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:{{{styling.Primary}}};stop-opacity:1" />
            <stop offset="100%" style="stop-color:{{{styling.Secondary}}};stop-opacity:1" />
          </linearGradient>
        </defs>
        <rect width="100%" height="100%" fill="url(#heroBgGradient)" />
      </svg>

      <!-- Partner Logos - Overlapping on top of gradient -->
      <div style="position: relative; z-index: 2; padding: 12px 24px;">
        <div class="partner-logos" style="display: inline-flex; gap: 16px; align-items: center; justify-content: flex-start; padding: 10px 18px; background: #fff; border-radius: 10px; box-shadow: 0 3px 10px rgba(0,0,0,0.15);">
          {{#if images.PartnerLogos}}
            {{#each images.PartnerLogos}}
              <img src="{{{this}}}" alt="Partner Logo" style="height: 38px; object-fit: contain;">
            {{/each}}
          {{/if}}
        </div>
      </div>

      <!-- Content Container -->
      <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; display: flex; align-items: stretch;">
        
        <!-- Left Side: Content (55%) -->
        <div style="flex: 0 0 55%; display: flex; flex-direction: column; justify-content: center; padding: 75px 24px 24px 32px; position: relative; z-index: 2;">
          <h1 style="font-size: 34px; margin: 0 0 12px 0; color: #fff; font-family: {{{styling.HeadingFont}}}; line-height: 1.1; letter-spacing: -0.6px; font-weight: 500; text-shadow: 0 2px 8px rgba(0,0,0,0.2);">{{content.Header.MainTitle}}</h1>
          
          <div style="display: flex; align-items: flex-start; gap: 12px; margin-top: 6px;">
            <div style="width: 3px; height: 45px; background: {{{styling.LightBg}}}; flex-shrink: 0; margin-top: 3px;"></div>
            <p style="font-size: 17px; margin: 0; color: {{{styling.LightBg}}}; font-weight: 500; line-height: 1.25; font-style: italic;">{{content.Header.Subtitle}}</p>
          </div>
        </div>

        <!-- Right Side: Image (45%) with blend -->
        {{#if images.TitleImage}}
          <div style="flex: 0 0 45%; position: relative; overflow: hidden;">
            <img src="{{{images.TitleImage}}}" alt="Program Highlight" style="width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.4) 10%, rgba(0,0,0,0.9) 25%, black 40%); -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.4) 10%, rgba(0,0,0,0.9) 25%, black 40%);">
          </div>
        {{/if}}
      </div>
      
      <!-- Bottom border/separator -->
      <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: rgba(255,255,255,0.2); z-index: 1;"></div>
    </div>

    <div class="container" style="width: 100%; padding: 10px 28px 8px 28px; display: flex; flex-direction: column; gap: 0;">

      <!-- Introduction - Compact -->
      <div class="intro" style="padding: 2px 0 0 0; margin: 0 0 8px 0; font-size: 11.5px; line-height: 1.45; text-align: justify; color: {{{styling.Text}}};">
        <div style="margin: 0 0 6px 0;">
          {{{content.Introduction.IntroParagraph}}}
        </div>
        {{#if content.Introduction.ProblemStatement}}
          <div style="margin-top: 6px; margin-bottom: 0;">
            <strong style="color: {{{styling.Primary}}}; font-weight: 600;">Why this matters:</strong>
            {{{content.Introduction.ProblemStatement}}}
          </div>
        {{/if}}
      </div>

      <!-- Benefits Section - Compact -->
      <div class="benefits-section" style="padding: 8px 12px; margin: 6px 0 0 0; background: transparent; border-radius: 5px;">
        <h2 class="benefits-title" style="font-size: 16px; text-align: center; color: {{{styling.Primary}}}; margin: 0 0 8px 0; font-family: {{{styling.HeadingFont}}}; font-weight: 600;">{{content.Benefits.Title}}</h2>
        <div class="benefits-grid" style="display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 7px;">
          {{#each content.Benefits.Items}}
            <div class="benefit-item" style="display: flex; gap: 7px; align-items: flex-start; background: {{{../styling.Panel}}}; border-left: 2px solid {{{../styling.Primary}}}; border-radius: 3px; padding: 6px 8px; font-size: 10px; line-height: 1.35; box-shadow: 0 1px 2px rgba(0,0,0,0.08);">
              <span class="benefit-icon" style="font-size: 11px; color: {{{../styling.Primary}}}; flex-shrink: 0; margin-top: 1px;">✓</span>
              <span style="flex: 1; color: {{{../styling.Text}}};">{{this}}</span>
            </div>
          {{/each}}
        </div>
      </div>
      
      <!-- User Interface Section - Compact -->
      <div class="user-interface-section" style="display: flex; gap: 12px; align-items: flex-start; margin-top: 8px; background: {{{styling.Secondary}}}; border-radius: 6px; padding: 10px; border: 1px solid rgba(255,255,255,0.2);">
        <div class="user-interface-text" style="flex: 1;">
          <h2 style="margin: 0 0 5px 0; font-size: 14px; color: {{{styling.Text}}}; font-family: {{{styling.HeadingFont}}}; font-weight: 600;">{{content.UserInterface.Heading}}</h2>
          <p style="margin: 0; font-size: 10px; color: {{{styling.Text}}}; line-height: 1.45;">{{content.UserInterface.Paragraph}}</p>
        </div>
        <div class="user-interface-image">
          {{#if images.UserInterfaceImage}}
            <img src="{{{images.UserInterfaceImage}}}" alt="User Interaction Preview" style="width: 180px; max-width: 180px; height: auto; border-radius: 6px; border: 2px solid rgba(255,255,255,0.3); box-shadow: 0 2px 6px rgba(0,0,0,0.15);">
          {{/if}}
        </div>
      </div>

      <!-- About REAN Foundation Section - Compact -->
      <div class="about-section" style="margin-top: 8px; padding: 10px 14px; background: {{{styling.Primary}}}; border-radius: 6px;">
        <h2 style="margin: 0 0 6px 0; font-size: 16px; color: #fff; font-family: {{{styling.HeadingFont}}}; font-weight: 700;">About REAN Foundation</h2>
        <p style="margin: 0; font-size: 10px; line-height: 1.5; color: #fff; text-align: justify;">REAN Foundation is focused on improving health equity for patients by making healthcare more accessible and affordable at home in the local language. We work towards building easy and convenient solutions that integrate seamlessly into a regular lifestyle to create sustainable habits to increase adherence and improve outcomes. We offer services for free and develop open-sourced products for a digital public good.</p>
      </div>

      <!-- CTA + QR Section - Compact -->
      <div class="last-cta" style="margin-top: 8px; padding: 10px 14px; background: {{{styling.Secondary}}}; display: flex; justify-content: space-between; align-items: center; gap: 12px; border-top: 2px solid rgba(255,255,255,0.25); border-radius: 6px;">
        <div class="cta-text" style="flex: 1;">
          <h3 style="margin: 0; font-size: 16px; font-family: {{{styling.HeadingFont}}}; color: #fff; letter-spacing: 0.2px; font-weight: 600;">{{content.Footer.CtaHeading}}</h3>
          <p style="margin: 4px 0 0; font-size: 10px; color: #fff; opacity: 0.95;">{{content.Footer.CtaDescription}}</p>
        </div>

        <div class="cta-qr" style="display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; min-width: 85px;">
          {{#if images.QRCode}}
            <img src="{{{images.QRCode}}}" alt="QR Code" style="width: 90px; height: 90px; padding: 5px; border-radius: 6px; background: #fff; border: 2px solid rgba(255,255,255,0.4); display: block; margin: 0;">
            <p class="scan" style="font-size: 8.5px; margin: 0; padding: 0; text-align: center; color: #fff; font-weight: 500; line-height: 1.2; display: block;">{{#if content.Footer.QrInstruction}}{{{content.Footer.QrInstruction}}}{{else}}Scan to get started{{/if}}</p>
          {{/if}}
        </div>
      </div>
    </div>

    <!-- Privacy Strip - Compact -->
    <div class="privacy-strip" style="position: absolute; left: 0; right: 0; bottom: 0; padding: 3px 20px; border-top: 1px solid rgba(0,0,0,0.08); font-size: 6.5px; color: {{{styling.Text}}}; display: flex; justify-content: space-between; align-items: center; gap: 8px; background: rgba(255,255,255,0.5);">
      <div class="policy" style="flex: 1; line-height: 1.2; text-align: left; color: {{{styling.Text}}};">
        <strong style="font-weight: 600; margin-right: 2px; color: {{{styling.Text}}};">Privacy:</strong> Protected under data protection laws. Policy: <a href="#" style="color: {{{styling.Text}}}; text-decoration: underline; font-weight: 500;">www.yourcompany.com/privacy</a> | DPO: +91 98230 44567
      </div>
      <div class="page-number" style="color: {{{styling.Text}}}; font-weight: 600; font-size: 7px; white-space: nowrap;">Page 1</div>
    </div>
  </div>

</body>
</html>
